{
    "name": "letmesendemail/letmesendemail-laravel",
    "description": "letmesend.email for Laravel.",
    "keywords": [
        "php",
        "letmesend",
        "letmesend-email",
        "laravel",
        "sdk",
        "api",
        "client"
    ],
    "homepage": "https://letmesend.email/",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "letmesendemail/letmesendemail-php": "^0.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.13",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^8.17|^9.0|^10.8|^11.0",
        "pestphp/pest": "^1.0|^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "LetMeSendEmail\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LetMeSendEmail\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LetMeSendEmail\\Laravel\\LetMeSendEmailServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
